# OpenClaw GitHub Integration Configuration

# Copy this file to .env and fill in your values.
# Keep .env out of version control!

# GitHub Personal Access Token (classic or fine-grained)
# Scopes needed: repo, workflow, read:org, gist
GH_TOKEN=ghp_YOUR_PAT_HERE

# Optional: GitHub Enterprise
# GH_HOST=github.com

# OpenClaw Gateway
# The URL that GitHub webhooks will call (must be publicly reachable with HTTPS)
# If behind a reverse proxy, set this to the public URL
OPENCLAW_URL=https://your-openclaw.example.com

# Webhook secret (generate a random 32+ char string)
WEBHOOK_SECRET=super-secret-random-string-here-min-32-chars
