#!/usr/bin/env bash
# Xander Maintainer CLI wrapper
# Usage: xander-maintainer review <PR_URL> [--output report.md]

set -euo pipefail

cd /root/.openclaw/workspace

# Ensure environment
if [ -f .env ]; then
    set -a
    source .env
    set +a
fi

# Use xander-operator venv Python explicitly
VENV_PY="/root/.openclaw/workspace/polish/xander-operator/.venv/bin/python"
if [ -x "$VENV_PY" ]; then
    exec "$VENV_PY" products/xander-maintainer/review_pr.py "$@"
else
    echo "Error: venv Python not found at $VENV_PY" >&2
    exit 1
fi
